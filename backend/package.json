{
  "name": "opencouncil-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "node:check": "node ../scripts/check-node-version.mjs",
    "native:check": "node scripts/ensure-better-sqlite.mjs",
    "predev": "pnpm run node:check && pnpm run native:check",
    "dev": "LOG_LEVEL=debug tsx watch src/server.ts",
    "prebuild": "pnpm run node:check && pnpm run native:check",
    "build": "tsc",
    "pretest": "pnpm run node:check && pnpm run native:check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
