{
  "name": "muti-agent-f001",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n \"backend,frontend\" -c \"blue,green\" \"pnpm --dir backend dev\" \"pnpm --dir frontend dev\"",
    "dev:backend": "pnpm --dir backend dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "install:all": "pnpm -r install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
